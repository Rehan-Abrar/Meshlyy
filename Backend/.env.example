# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Apify
APIFY_API_KEY=
APIFY_ACTOR_ID=
DAILY_APIFY_SPEND_CAP=             # in USD, e.g. 5
APIFY_TIMEOUT_MS=30000

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
DAILY_AI_TOKEN_CAP=                # e.g. 100000
GEMINI_TIMEOUT_MS=30000

# AI provider routing
AI_PROVIDER=gemini                 # gemini or groq (gemini falls back to groq when available)

# Groq fallback provider
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=30000

# Request timeout
REQUEST_TIMEOUT_MS=5000

# Ingest worker hardening
INGEST_WORKER_POLL_MS=30000
INGEST_REFRESH_INTERVAL_HOURS=24
INGEST_STALE_RUNNING_MINUTES=20
INGEST_MAX_RETRIES=3
INGEST_RETRY_BASE_MS=60000

# Email
EMAIL_PROVIDER=resend              # resend or gmail
EMAIL_FROM=onboarding@resend.dev  # resend: onboarding@resend.dev (dev) / noreply@meshly.pk (prod)
RESEND_API_KEY=
RESEND_EMAIL_FROM=onboarding@resend.dev
GMAIL_EMAIL=
GMAIL_PASSWORD=                   # Gmail app password (for MVP demos)

# Engagement anomaly threshold
ENGAGEMENT_ANOMALY_THRESHOLD=0.01  # tune later