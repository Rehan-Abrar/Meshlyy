# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
JWT_SECRET=                        # Supabase JWT secret (from project settings)
PORT=3000
NODE_ENV=development

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Apify
APIFY_API_TOKEN=
APIFY_ACTOR_ID=
APIFY_DAILY_SPEND_CAP=             # in USD, e.g. 5

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_DAILY_TOKEN_CAP=                # e.g. 100000

# Email
EMAIL_PROVIDER=resend              # resend or gmail
EMAIL_FROM=onboarding@resend.dev  # resend: onboarding@resend.dev (dev) / noreply@meshly.pk (prod)
RESEND_API_KEY=
RESEND_EMAIL_FROM=onboarding@resend.dev
GMAIL_EMAIL=
GMAIL_PASSWORD=                   # Gmail app password (for MVP demos)

# Engagement anomaly threshold
ENGAGEMENT_ANOMALY_THRESHOLD=0.01  # tune later